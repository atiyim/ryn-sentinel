{
  "name": "ryn-sentinel",
  "version": "1.0.0",
  "description": "Ryn Sentinel - ZenitMC Moderasyon Sistemi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "googleapis": "^171.4.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.rynsentinel.app",
    "productName": "Ryn Sentinel",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "atiyim",
      "repo": "ryn-sentinel"
    }
  }
}
